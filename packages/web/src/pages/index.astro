---
import { diff, type Profile, SCHEMA_VERSION } from "@ymmv/shared";
import Diff from "../components/Diff.astro";
import InstallCommand from "../components/InstallCommand.astro";
import Layout from "../components/Layout.astro";
import ProfileExample from "../components/Profile.astro";

// Landing: the pitch + the one-line install + a representative example of what a profile — and a
// diff — look like. Both examples are static (clearly labelled) so the landing always renders,
// independent of the DB.
const octocatProfile: Profile = {
  schema_version: SCHEMA_VERSION,
  handle: "octocat",
  entries: [
    { key: "editor", value: "Neovim" },
    { key: "os", value: "macOS 15.2" },
    { key: "shell", value: "fish" },
    { key: "prompt", value: "Starship" },
    { key: "terminal", value: "Ghostty" },
    { key: "browser", value: "Zen" },
    { key: "window-manager", value: "Aerospace" },
    { key: "font", value: "Berkeley Mono" },
    { key: "theme", value: "Catppuccin Mocha" },
    { key: "multiplexer", value: "tmux" },
    { key: "version-manager", value: "mise" },
    // dotfiles is a curated stack key — keep the example grouped exactly like a live profile
    { key: "dotfiles", value: "https://github.com/octocat/dotfiles" },
    { key: "ai-tool", value: "Claude Code" },
  ],
  extras: [{ label: "Keyboard", value: "HHKB Pro 2" }],
  updated_at: "2026-06-28T00:00:00.000Z",
};

// A second static persona to diff octocat against — GitHub's other mascot, so the pairing reads as
// illustrative, not a real user. Tuned to 7 differ / 6 shared: it keeps the mac-terminal core (os,
// prompt, terminal, window-manager, theme, multiplexer) and diverges on editor/shell/browser/font/
// version-manager/ai-tool, omitting dotfiles — so all three diff states show (changed, same, and a
// missing "—" row). octocat is reused verbatim, so the reader already knows the left column.
const hubotProfile: Profile = {
  schema_version: SCHEMA_VERSION,
  handle: "hubot",
  entries: [
    { key: "editor", value: "VS Code" },
    { key: "os", value: "macOS 15.2" },
    { key: "shell", value: "zsh" },
    { key: "prompt", value: "Starship" },
    { key: "terminal", value: "Ghostty" },
    { key: "browser", value: "Arc" },
    { key: "window-manager", value: "Aerospace" },
    { key: "font", value: "JetBrains Mono" },
    { key: "theme", value: "Catppuccin Mocha" },
    { key: "multiplexer", value: "tmux" },
    { key: "version-manager", value: "asdf" },
    { key: "ai-tool", value: "Copilot" },
  ],
  extras: [],
  updated_at: "2026-06-28T00:00:00.000Z",
};

// diff(mine, theirs): mine=hubot, theirs=octocat → octocat renders in the LEFT value column (under
// the profile example above it), hubot on the right. Computed at build time; the engine is DB-free.
const exampleDiff = diff(hubotProfile, octocatProfile);
---

<Layout title="ymmv.fyi — your stack, in the terminal">
  <section class="hero">
    <h1 class="wordmark">ymmv<span class="dim">.fyi</span></h1>
    <p class="tagline">
      <span class="lead">The tools you actually use</span>, at <code>ymmv.fyi/you</code>.<br />
      <b>Publish from the CLI</b>, then diff against anyone's.
    </p>
    <InstallCommand />
  </section>

  <h2 class="example-label">A profile looks like this</h2>
  <div class="sample">
    <ProfileExample profile={octocatProfile} example />
  </div>

  <h2 class="example-label">A diff looks like this</h2>
  <div class="sample">
    <Diff result={exampleDiff} theirs="octocat" mine="hubot" example />
  </div>

  <footer class="site-foot">
    <p class="foot-h">Reference</p>
    <div class="fg">
      <span class="g">terminal</span>
      <div class="fl">
        <code>npx ymmv-cli</code>
        <span class="n">publish your stack</span>
      </div>
      <div class="fl">
        <code>npx ymmv-cli &lt;handle&gt;</code>
        <span class="n">view, or diff vs yours</span>
      </div>
    </div>
    <div class="fg">
      <span class="g">web</span>
      <div class="fl">
        <code>ymmv.fyi/&lt;handle&gt;</code>
        <span class="n">a profile</span>
      </div>
      <div class="fl">
        <code>ymmv.fyi/&lt;handle&gt;/vs/&lt;you&gt;</code>
        <span class="n">the diff</span>
      </div>
    </div>
    <div class="fg">
      <span class="g">data</span>
      <div class="fl">
        <code>GET /api/v1/u/&lt;handle&gt;</code>
        <span class="n">json</span>
      </div>
    </div>
    <div class="fg">
      <span class="g">source</span>
      <div class="fl">
        <a href="https://github.com/ymmv-fyi/ymmv">github.com/ymmv-fyi/ymmv</a>
        <span class="n">code + issues</span>
      </div>
    </div>
  </footer>
</Layout>
