---
// The profile spec sheet — handle + key->value stack + extras + footer, per DESIGN.md.
// All values are user-controlled: Astro auto-escapes every {value}; URL values are gated through
// safeHref before becoming an href (escaping does not neutralize a javascript: scheme).
//
// `example`: when this is the landing-page sample (not the page's own profile), render the handle
// and group headers as non-headings so they don't pollute the document outline / emit a 2nd <h1>.
// Row labels are real <th scope="row"> for screen-reader header association.
import { KEY_LABELS, type Profile } from "@ymmv/shared";
import { displayUrl, urlTitle } from "../lib/display-value.ts";
import InstallCommand from "./InstallCommand.astro";
import { safeHref } from "../lib/safe-href.ts";

interface Props {
  profile: Profile;
  example?: boolean;
}
const { profile, example = false } = Astro.props;
const { handle, entries, extras, updated_at } = profile;
const hasStack = entries.length > 0;
const hasExtras = extras.length > 0;
// spec-sheet revision stamp: date part only (the wire carries a full ISO timestamp)
const revDate = updated_at?.slice(0, 10);

const HandleTag = example ? "p" : "h1";
const GroupTag = example ? "p" : "h2";
---

<div class="url">{example ? "ymmv.fyi" : <a href="/">ymmv.fyi</a>}/<b>{handle}</b></div>
<HandleTag class="handle">{handle}</HandleTag>
{revDate && (
  <p class="rev">updated <time datetime={updated_at}>{revDate}</time></p>
)}

{
  hasStack && (
    <>
      <GroupTag class="group-h">Stack</GroupTag>
      <table class="spec">
        <tbody>
          {entries.map((e) => {
            const href = safeHref(e.value);
            return (
              <tr>
                <th scope="row" class="k">
                  {KEY_LABELS[e.key]}
                </th>
                <td class="v">
                  {href ? (
                    <a
                      href={href}
                      rel="nofollow ugc noopener noreferrer"
                      target="_blank"
                      title={urlTitle(e.value)}
                    >
                      {displayUrl(e.value)}
                    </a>
                  ) : (
                    e.value
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </>
  )
}

{
  hasExtras && (
    <>
      <GroupTag class="group-h">Extras</GroupTag>
      <table class="spec">
        <tbody>
          {extras.map((x) => {
            const href = safeHref(x.value);
            return (
              <tr>
                <th scope="row" class="k">
                  {x.label}
                </th>
                <td class="v">
                  {href ? (
                    <a
                      href={href}
                      rel="nofollow ugc noopener noreferrer"
                      target="_blank"
                      title={urlTitle(x.value)}
                    >
                      {displayUrl(x.value)}
                    </a>
                  ) : (
                    x.value
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </>
  )
}

{!hasStack && !hasExtras && <p class="empty-msg">No stack published yet.</p>}

{
  example ? (
    <div class="foot">$ <b>npx ymmv-cli@latest {handle}</b></div>
  ) : (
    <div class="foot"><InstallCommand command={`npx ymmv-cli@latest ${handle}`} /></div>
  )
}
{!example && (
  <>
    <p class="cta">
      make yours → <b>npx ymmv-cli@latest</b>
    </p>
    {/* action → the profile page, whose ?you= handler 302s to the diff: a native (script-failed)
        submit works from anywhere this form renders, including the /vs/ nudge page */}
    <form class="cta diff-cta" action={`/${handle}`} data-diff-vs={handle}>
      <label>
        <svg class="fork" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 9.5h12M4.5 9.5 8 4.5h5" stroke="currentColor" stroke-width="1.2" />
        </svg>
        diff vs{" "}
        <input
          class="you"
          name="you"
          placeholder="<you>"
          maxlength="39"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          aria-label={`your handle — diff ${handle} against you`}
        />
      </label>
      <button class="go" type="submit" aria-label="view the diff"
        ><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 9h12M10 4.5 14.5 9 10 13.5" /></svg></button
      >
    </form>
    <noscript>
      {/* is:inline — Astro must not hoist this out of the <noscript> gate */}
      <style is:inline>
        .diff-cta {
          display: none;
        }
      </style>
      <p class="cta">
        diff → <b>ymmv.fyi/{handle}/vs/&lt;you&gt;</b>
      </p>
    </noscript>
  </>
)}
