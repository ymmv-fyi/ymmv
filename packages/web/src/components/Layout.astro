---
// The page shell: head + design-system CSS + self-hosted fonts + the dark-primary theme system.
// Every page renders inside this. User-controlled text is passed through Astro's auto-escaping
// {expression} interpolation — NEVER set:html on a profile field.
import { Font } from "astro:assets";
import "../styles/ymmv.css";

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Terminal-native developer tool-stack profiles. Your mileage may vary." } =
  Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="darkreader-lock" />
    {/* Browser-UI color (mobile toolbar/overscroll). Hexes mirror the --bg tokens in ymmv.css;
        JS-synced (not media-attr metas) because the stored choice overrides prefers-color-scheme.
        Must precede the no-FOUC script, which sets it to the resolved theme. */}
    <meta name="theme-color" content="#0e0c09" />
    {/* Set the theme before first paint (stored choice > system > dark) to avoid a flash. */}
    <script is:inline>
      (function () {
        // localStorage gets its own guard: a storage-blocked browser must still fall
        // through to the prefers-color-scheme check, not skip it via a shared catch.
        var stored = null;
        try {
          stored = localStorage.getItem("ymmv-theme");
        } catch (e) {}
        // whitelist: arbitrary storage garbage must not become a token-less data-theme value
        if (stored !== "light" && stored !== "dark") stored = null;
        var theme = stored;
        if (!theme) {
          try {
            theme = matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
          } catch (e) {
            theme = "dark";
          }
        }
        document.documentElement.dataset.theme = theme;
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute("content", theme === "light" ? "#f6f3ea" : "#0e0c09");
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {/* Fonts via Astro's Fonts API: each <Font> injects the inlined @font-face + size-matched fallback
        + a preload for the above-the-fold file. Mono preload is scoped to 400@latin (the body face);
        500/600 + latin-ext stay on demand via unicode-range. Exactly 3 preloads total (e2e-pinned). */}
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-mono" preload={[{ weight: 400, subset: "latin" }]} />
    <Font cssVariable="--font-serif" preload />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {/* static brand card (wordmark + fork motif). og:image must be absolute — Astro.site, never
        Astro.url.origin (that would bake localhost/www variants per request). */}
    <meta property="og:image" content={new URL("/og.png", Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ymmv.fyi. Your mileage may vary." />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark or light theme">
      ◐ theme
    </button>
    <main class="page">
      <slot />
    </main>
    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        var THEME_KEY = "ymmv-theme"; // the pre-paint head script keeps its own literal (self-contained)
        function current() {
          return document.documentElement.dataset.theme === "light" ? "light" : "dark";
        }
        function storedTheme() {
          // Guarded read + whitelist, mirroring the pre-paint script: storage garbage (a stray
          // value from another tab) and a storage-blocked browser both resolve to null (no choice).
          var stored = null;
          try {
            stored = localStorage.getItem(THEME_KEY);
          } catch (e) {}
          return stored === "light" || stored === "dark" ? stored : null;
        }
        function syncPressed() {
          // aria-pressed=true ⇒ the non-default (light) theme is active
          btn.setAttribute("aria-pressed", String(current() === "light"));
        }
        function syncThemeColor() {
          // Keep the browser UI (mobile toolbar/overscroll) on the active --bg. Read the token
          // from CSS (this script runs after the stylesheet) so a palette change can't desync it;
          // only the pre-paint head script keeps hex literals.
          var meta = document.querySelector('meta[name="theme-color"]');
          if (!meta) return;
          var bg = getComputedStyle(document.documentElement).getPropertyValue("--bg").trim();
          if (bg) meta.setAttribute("content", bg);
        }
        function setTheme(theme) {
          // Apply a resolved theme to every surface: data-theme, the toggle state, the browser UI.
          document.documentElement.dataset.theme = theme;
          syncPressed();
          syncThemeColor();
        }
        function applyTheme() {
          // Resolve exactly as the pre-paint script does (stored choice > system > dark) and
          // re-sync every surface. Single source of the whitelist + fallback for all the resync
          // paths below (BFCache restore, cross-tab storage, system-preference change).
          var theme = storedTheme();
          if (!theme) {
            try {
              theme = matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
            } catch (e) {
              theme = "dark";
            }
          }
          setTheme(theme);
        }
        syncPressed(); // expose the toggle state at load, not only after the first click
        btn.addEventListener("click", function () {
          var next = current() === "dark" ? "light" : "dark";
          try {
            localStorage.setItem(THEME_KEY, next);
          } catch (e) {}
          setTheme(next);
        });
        // BFCache restore: a page served from the back-forward cache never re-runs the pre-paint
        // head script, so its data-theme can be stale. Re-resolve only on a persisted restore.
        window.addEventListener("pageshow", function (e) {
          if (e.persisted) applyTheme();
        });
        // Cross-tab: a toggle in another same-origin tab writes ymmv-theme; mirror it here. A
        // removeItem fires with newValue null, which storedTheme() reads as no choice → system.
        // key null = localStorage.clear() in another tab, which wiped the choice too.
        window.addEventListener("storage", function (e) {
          if (e.key === null || e.key === THEME_KEY) applyTheme();
        });
        try {
          var mq = matchMedia("(prefers-color-scheme: light)");
          mq.addEventListener("change", function () {
            // Follow the system only when there is no stored choice; applyTheme owns the
            // whitelist + fallback (and its own storage guard), so this stays one source of truth.
            if (!storedTheme()) applyTheme();
          });
        } catch (e) {}
      })();
    </script>
    {/* Click-to-copy for the install CTA(s). Progressive enhancement: only wires up (and reveals
        the copy affordance) when the Clipboard API is available; otherwise the command stays
        plain readable/selectable text. One delegated handler covers every [data-copy] block. */}
    <script is:inline>
      (function () {
        if (!navigator.clipboard) return;
        var nodes = document.querySelectorAll("[data-copy]");
        nodes.forEach(function (el) {
          // Promote the plain span to an ARIA button now that copying actually works, so a
          // keyboard/AT user only reaches an operable control when the clipboard path is live
          // (no dead button with JS off). The action wording in the label is required a11y copy.
          el.setAttribute("role", "button");
          el.setAttribute("tabindex", "0");
          el.setAttribute("aria-label", "Copy install command: " + el.dataset.copy);
          el.dataset.copyReady = "";
          var status = el.querySelector("[data-copy-status]");
          var timer;
          function copy() {
            navigator.clipboard
              .writeText(el.dataset.copy)
              .then(function () {
                el.dataset.copied = "";
                if (status) status.textContent = "Copied";
                clearTimeout(timer);
                timer = setTimeout(function () {
                  delete el.dataset.copied;
                  if (status) status.textContent = "";
                }, 1200);
              })
              .catch(function () {
                // Clipboard blocked by policy (NotAllowedError): announce the failure instead of
                // an operable control that silently does nothing. No data-copied, so the glyph
                // never fakes success.
                if (status) status.textContent = "Copy failed";
                clearTimeout(timer);
                timer = setTimeout(function () {
                  if (status) status.textContent = "";
                }, 1200);
              });
          }
          el.addEventListener("click", copy);
          el.addEventListener("keydown", function (ev) {
            // Enter and Space activate a button. preventDefault on Space so it copies instead of
            // scrolling the page. data-pressed mirrors :active for keyboard presses (a role=button
            // span never enters :active from the keyboard).
            if (ev.key === "Enter" || ev.key === " ") {
              ev.preventDefault();
              el.dataset.pressed = "";
              copy();
            }
          });
          el.addEventListener("keyup", function (ev) {
            if (ev.key === "Enter" || ev.key === " ") delete el.dataset.pressed;
          });
          el.addEventListener("blur", function () {
            // focus can leave with the key still held; never leave the pressed state stuck
            delete el.dataset.pressed;
          });
        });
      })();
    </script>
    {/* The profile page's inline "diff vs <you>" form. Navigates to /<handle>/vs/<you> and
        remembers the entered handle (the input is the only write point — the web has no auth),
        so return visits are prefilled. No-JS keeps the <noscript> URL-pattern hint instead. */}
    <script is:inline>
      (function () {
        var form = document.querySelector("[data-diff-vs]");
        if (!form) return;
        var input = form.querySelector("input");
        if (!input) return;
        try {
          var last = localStorage.getItem("ymmv-you");
          if (last && !input.value) input.value = last;
        } catch (e) {}
        form.addEventListener("submit", function (ev) {
          ev.preventDefault();
          var you = input.value.trim().replace(/^@+/, "");
          // Mirror the server's isValidHandle (GitHub handle shape, ≤39). Without this, "." or
          // ".." survive encodeURIComponent and the browser normalizes the dot-segments away
          // (silent self-navigation), and garbage would be persisted + prefilled forever.
          if (!/^[a-zA-Z0-9](?:-?[a-zA-Z0-9])*$/.test(you) || you.length > 39) {
            input.focus();
            return;
          }
          try {
            localStorage.setItem("ymmv-you", you);
          } catch (e) {}
          location.href =
            "/" + encodeURIComponent(form.dataset.diffVs) + "/vs/" + encodeURIComponent(you);
        });
      })();
    </script>
  </body>
</html>
