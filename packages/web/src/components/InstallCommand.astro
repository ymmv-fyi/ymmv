---
// The one-line install command — the primary CTA, shown on the landing hero and the empty/404
// state. Rendered as a plain <span> so with no JS / no Clipboard API it stays selectable text and
// never a dead control; the delegated [data-copy] inline script in Layout.astro promotes it to an
// ARIA button (role + tabindex + aria-label) and reveals the copy affordance only once wired
// (progressive enhancement). The trailing glyph morphs clipboard → check on success (Emil: "state
// indication"); the sr-only live region announces it.
interface Props {
  command?: string;
}
// `@latest` and not the bare name: npx caches the bare spec and reuses it indefinitely, so a
// returning visitor would keep running whatever version their npx cache pinned months ago.
const { command = "npx ymmv-cli@latest" } = Astro.props;
---

<span
  class="install"
  data-copy={command}
><span class="prompt">$ </span>{command}<span class="copy-hint" aria-hidden="true"><span class="ch ch-idle"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg></span><span class="ch ch-done"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg></span></span><span class="sr-only" data-copy-status aria-live="polite"></span></span>
