---
// The one-line install command, rendered as a click-to-copy button — the primary CTA, shown on
// the landing hero and the empty/404 state. Copy behavior is wired by the delegated [data-copy]
// inline script in Layout.astro (progressive enhancement): with no JS / no Clipboard API the
// affordance stays hidden and the command is plain, selectable text. The trailing glyph morphs
// clipboard → check on success (Emil: "state indication"); the sr-only live region announces it.
interface Props {
  command?: string;
}
const { command = "npx ymmv-cli" } = Astro.props;
---

<button
  class="install"
  type="button"
  data-copy={command}
  aria-label={`Copy install command: ${command}`}
><span class="prompt">$ </span>{command}<span class="copy-hint" aria-hidden="true"><span class="ch ch-idle"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg></span><span class="ch ch-done"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg></span></span><span class="sr-only" data-copy-status aria-live="polite"></span></button>
